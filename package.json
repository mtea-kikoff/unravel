{
  "name": "unravel",
  "productName": "Unravel",
  "version": "0.1.0",
  "description": "Download every attachment from a Gmail thread as one zip.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-packager . Unravel --platform=darwin --arch=arm64 --icon=build/icon --out=dist --overwrite"
  },
  "author": "Michael Tea",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.3",
    "electron": "^33.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "googleapis": "^140.0.0"
  },
  "allowScripts": {
    "electron@33.4.11": true
  }
}
